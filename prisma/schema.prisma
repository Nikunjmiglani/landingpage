generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  mobile    String?    @unique
  password  String
  role      Role       @default(CANDIDATE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  candidate Candidate?
}

model Candidate {
  id           String          @id @default(cuid())
  userId       String          @unique
  firstName    String
  lastName     String
  city         String?
  degree       String?
  branch       String?
  college      String?
  gradYear     String?
  cgpa         String?
  experience   String          @default("fresher")
  jobType      String?
  locations    String[]
  salary       String?
  skills       String[]
  profileScore Int             @default(0)
  status       CandidateStatus @default(ONBOARDING)
  counsellorId String?
  resumeUrl    String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  applications Application[]
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents    Document[]
}

model Job {
  id           String           @id @default(cuid())
  company      String
  role         String
  location     String?
  jobType      JobType?
  experience   ExperienceLevel?
  salary       String?
  openings     Int              @default(1)
  skills       String[]
  description  String?
  deadline     DateTime?
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  applications Application[]
}

model Application {
  id              String    @id @default(cuid())
  candidateId     String
  jobId           String
  status          AppStatus @default(APPLIED)
  appliedAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  interviewDate   DateTime?
  notes           String?
  offerSalary     String?
  rejectionReason String?
  candidate       Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job             Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([candidateId, jobId])
}

model Document {
  id          String    @id @default(cuid())
  candidateId String
  name        String
  type        String
  url         String
  status      DocStatus @default(UPLOADED)
  uploadedAt  DateTime  @default(now())
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

enum Role {
  CANDIDATE
  ADMIN
  COUNSELLOR
}

enum CandidateStatus {
  ONBOARDING
  RESUME_REVIEW
  INTERVIEW_STAGE
  OFFER_RECEIVED
  PLACED
}

enum AppStatus {
  APPLIED
  UNDER_REVIEW
  INTERVIEW_SCHEDULED
  OFFER_RECEIVED
  REJECTED
  PLACED
}

enum DocStatus {
  UPLOADED
  APPROVED
  REJECTED
  PENDING
}

enum JobType {
  FULL_TIME
  INTERNSHIP
  PART_TIME
  CONTRACT
  FREELANCE
}

enum ExperienceLevel {
  FRESHER
  ONE_TO_THREE
  THREE_TO_FIVE
  FIVE_PLUS
}
